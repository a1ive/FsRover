	PUSHBUTTON	"浏览", IDC_CRYPTO_BROWSE, 187, 59, 46, 14, WS_DISABLED
	CONTROL		"", IDC_CRYPTO_PROGRESS, "msctls_progress32", WS_BORDER | NOT WS_VISIBLE, 7, 80, 226, 8
	DEFPUSHBUTTON	"确定", IDOK, 128, 100, 50, 14
	PUSHBUTTON	"取消", IDCANCEL, 183, 100, 50, 14
