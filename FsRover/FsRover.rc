#pragma code_page(65001)

#include <winresrc.h>

#include "resource.h"
#include "version.h"
#include "../filetype/resource.h"

/////////////////////////////////////////////////////////////////////////////
// Language-neutral

LANGUAGE LANG_NEUTRAL, SUBLANG_NEUTRAL

// Pixel-art app icon: Mars rover driving on a hard-disk platter
// (16/32 hand-drawn masters, 48/64/128/256 nearest-neighbor scaled).
IDI_APP ICON "FsRover.ico"

// Compiled magic.mgc (zstd -19); inflated at runtime by filetype.lib
// with the zstd decoder from grub.lib.  See filetype\magic\.
IDR_FILETYPE_MAGIC_ZST RCDATA "../filetype/magic/magic.zst"

// Bundled Dokan runtime for the build architecture: user-mode library
// (dokan2.dll), kernel driver (dokan2.sys) and its security catalog
// (dokan2.cat).  Dokan > Install Dokan writes these to the system and
// registers the catalog when no Dokan driver is present.  The catalog is
// required because dokan2.sys is catalog-signed, not embedded-signed, so
// the kernel refuses to load it on a machine that never had Dokan.  Only
// the matching architecture is bundled (WoW64 is out of scope); the arch
// macro comes from the vcxproj ResourceCompile preprocessor definitions.
#if defined(ROVER_ARCH_X64)
IDR_DOKAN_DLL RCDATA "dokan/prebuilt/x64/dokan2.dll"
IDR_DOKAN_SYS RCDATA "dokan/prebuilt/x64/dokan2.sys"
IDR_DOKAN_CAT RCDATA "dokan/prebuilt/x64/dokan2.cat"
#elif defined(ROVER_ARCH_ARM64)
IDR_DOKAN_DLL RCDATA "dokan/prebuilt/ARM64/dokan2.dll"
IDR_DOKAN_SYS RCDATA "dokan/prebuilt/ARM64/dokan2.sys"
IDR_DOKAN_CAT RCDATA "dokan/prebuilt/ARM64/dokan2.cat"
#elif defined(ROVER_ARCH_X86)
IDR_DOKAN_DLL RCDATA "dokan/prebuilt/x86/dokan2.dll"
IDR_DOKAN_SYS RCDATA "dokan/prebuilt/x86/dokan2.sys"
IDR_DOKAN_CAT RCDATA "dokan/prebuilt/x86/dokan2.cat"
#endif

// Hex viewer: a 64-bit offset bar above one virtual list view.  All
// translatable text is replaced from the string table at runtime, so a
// single language-neutral template serves every UI language.
IDD_HEX DIALOGEX 0, 0, 400, 240
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MAXIMIZEBOX
CAPTION "Hex view"
FONT 9, "Segoe UI"
BEGIN
	LTEXT		"", IDC_HEX_OFFSET_LABEL, 4, 5, 42, 10
	EDITTEXT	IDC_HEX_OFFSET_EDIT, 48, 2, 110, 14, ES_AUTOHSCROLL
	DEFPUSHBUTTON	"Go", IDC_HEX_GO, 161, 2, 34, 14
	PUSHBUTTON	"<", IDC_HEX_PREV, 198, 2, 24, 14
	PUSHBUTTON	">", IDC_HEX_NEXT, 225, 2, 24, 14
	CONTROL	"", IDC_HEX_LIST, "SysListView32", LVS_REPORT | LVS_OWNERDATA | LVS_SHOWSELALWAYS | WS_TABSTOP, 0, 20, 400, 220, WS_EX_CLIENTEDGE
END

// Text viewer: encoding/wrap/line-number/font bar above a read-only
// RichEdit (Msftedit.dll is loaded before the dialog is created).  All
// translatable text is replaced from the string table at runtime, so a
// single language-neutral template serves every UI language.
IDD_TEXT DIALOGEX 0, 0, 480, 300
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MAXIMIZEBOX
CAPTION "Text view"
FONT 9, "Segoe UI"
BEGIN
	LTEXT		"", IDC_TEXT_ENC_LABEL, 4, 5, 44, 10
	COMBOBOX	IDC_TEXT_ENCODING, 50, 3, 70, 90, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
	CONTROL		"", IDC_TEXT_WRAP, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 124, 4, 60, 12
	CONTROL		"", IDC_TEXT_LINENUM, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 188, 4, 60, 12
	PUSHBUTTON	"", IDC_TEXT_FONT, 252, 2, 40, 14
	LTEXT		"", IDC_TEXT_INFO, 296, 5, 180, 10, SS_ENDELLIPSIS
	CONTROL		"", IDC_TEXT_EDIT, "RICHEDIT50W", ES_MULTILINE | ES_READONLY | ES_NOHIDESEL | ES_AUTOHSCROLL | ES_AUTOVSCROLL | WS_VSCROLL | WS_HSCROLL | WS_TABSTOP, 0, 20, 480, 280, WS_EX_CLIENTEDGE
END

// Image viewer: no controls, the whole client area is rendered with
// Direct2D (d2d1.dll is loaded at runtime).  All text lives in the
// caption, so a single language-neutral template serves every UI
// language.
IDD_IMAGE DIALOGEX 0, 0, 480, 300
STYLE DS_SETFONT | WS_POPUP | WS_CAPTION | WS_SYSMENU | WS_THICKFRAME | WS_MAXIMIZEBOX
CAPTION "Image view"
FONT 9, "Segoe UI"
BEGIN
END

// About box: app icon, version/copyright, third-party credits.  The
// caption and credits label come from the string table at runtime; the
// copyright and the credits list are ASCII and language-neutral.
IDD_ABOUT DIALOGEX 0, 0, 280, 190
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "About"
FONT 9, "Segoe UI"
BEGIN
	CONTROL		"", IDC_ABOUT_ICON, "Static", SS_ICON, 12, 12, 21, 20
	LTEXT		"", IDC_ABOUT_NAME, 44, 12, 229, 10
	LTEXT		ROVER_COPYRIGHT, IDC_STATIC, 44, 24, 229, 10
	LTEXT		"Licensed under the GNU General Public License v3.", IDC_STATIC, 44, 36, 229, 10
	LTEXT		"", IDC_ABOUT_CREDITS_LABEL, 12, 54, 261, 10
	EDITTEXT	IDC_ABOUT_CREDITS, 12, 66, 261, 98, ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL | WS_VSCROLL
	DEFPUSHBUTTON	"OK", IDOK, 223, 169, 50, 14
END

// Supported features: per-category name lists, filled at runtime from
// the grub registration lists (backend_get_support).
IDD_SUPPORT DIALOGEX 0, 0, 320, 250
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Supported features"
FONT 9, "Segoe UI"
BEGIN
	EDITTEXT	IDC_SUPPORT_TEXT, 7, 7, 306, 214, ES_MULTILINE | ES_READONLY | ES_AUTOVSCROLL | WS_VSCROLL
	DEFPUSHBUTTON	"OK", IDOK, 263, 229, 50, 14
END

// Dokan mount options: drive-letter picker plus an open-in-Explorer
// switch.  All translatable text is replaced from the string table at
// runtime, so a single language-neutral template serves every UI
// language.
IDD_DOKANMOUNT DIALOGEX 0, 0, 220, 91
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Mount to drive letter"
FONT 9, "Segoe UI"
BEGIN
	LTEXT		"", IDC_DOKAN_INFO, 7, 7, 206, 10
	LTEXT		"", IDC_DOKAN_LETTER_LABEL, 7, 25, 60, 8
	COMBOBOX	IDC_DOKAN_LETTER, 70, 23, 50, 90, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
	CONTROL		"", IDC_DOKAN_EXPLORER, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 7, 43, 206, 10
	DEFPUSHBUTTON	"OK", IDOK, 108, 70, 50, 14
	PUSHBUTTON	"Cancel", IDCANCEL, 163, 70, 50, 14
END

VS_VERSION_INFO VERSIONINFO
FILEVERSION ROVER_VERSION
PRODUCTVERSION ROVER_VERSION
FILEFLAGSMASK VS_FFI_FILEFLAGSMASK
#ifdef _DEBUG
FILEFLAGS VS_FF_DEBUG
#else
FILEFLAGS 0x0L
#endif
FILEOS VOS_NT_WINDOWS32
FILETYPE VFT_APP
FILESUBTYPE 0x0L
BEGIN
	BLOCK "StringFileInfo"
	BEGIN
		BLOCK "000004B0"
		BEGIN
			VALUE "CompanyName", ROVER_COMPANY "\0"
			VALUE "FileDescription", ROVER_FILEDESC "\0"
			VALUE "FileVersion", ROVER_VERSION_STR "\0"
			VALUE "InternalName", ROVER_INTERNALNAME "\0"
			VALUE "LegalCopyright", ROVER_COPYRIGHT "\0"
			VALUE "OriginalFilename", ROVER_ORIGINALNAME "\0"
			VALUE "ProductName", ROVER_PRODUCT "\0"
			VALUE "ProductVersion", ROVER_VERSION_STR "\0"
		END
	END
	BLOCK "VarFileInfo"
	BEGIN
		VALUE "Translation", 0x0000, 1200
	END
END

