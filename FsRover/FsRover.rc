// Cryptodisk unlock: passphrase (or a key file) for a LUKS/LUKS2 volume.
IDD_CRYPTO DIALOGEX 0, 0, 240, 122
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Unlock Encrypted Volume"
FONT 9, "Segoe UI"
BEGIN
	LTEXT		"", IDC_CRYPTO_INFO, 7, 7, 226, 16
	LTEXT		"Passphrase:", IDC_STATIC, 7, 28, 60, 8
	EDITTEXT	IDC_CRYPTO_PASS, 70, 26, 163, 12, ES_PASSWORD | ES_AUTOHSCROLL
	CONTROL		"Use a key file instead", IDC_CRYPTO_USEKEYFILE, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 7, 46, 160, 10
	EDITTEXT	IDC_CRYPTO_KEYFILE, 7, 60, 176, 12, ES_READONLY | ES_AUTOHSCROLL | WS_DISABLED
	PUSHBUTTON	"Browse", IDC_CRYPTO_BROWSE, 187, 59, 46, 14, WS_DISABLED
	CONTROL		"", IDC_CRYPTO_PROGRESS, "msctls_progress32", WS_BORDER | NOT WS_VISIBLE, 7, 80, 226, 8
	DEFPUSHBUTTON	"OK", IDOK, 128, 100, 50, 14
	PUSHBUTTON	"Cancel", IDCANCEL, 183, 100, 50, 14
END

// File properties: libmagic description on top, hash calculator below
// (layout borrowed from FileXRay's property page).
IDD_PROPS DIALOGEX 0, 0, 227, 196
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Properties"
FONT 9, "Segoe UI"
BEGIN
	GROUPBOX	"File", IDC_STATIC, 7, 7, 213, 43
	EDITTEXT	IDC_PROPS_TYPE, 17, 20, 197, 21, ES_MULTILINE | ES_READONLY | ES_AUTOHSCROLL | WS_BORDER | WS_TABSTOP

	GROUPBOX	"Hash", IDC_STATIC, 7, 55, 213, 134
	CONTROL		"MD5", IDC_PROPS_MD5, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 17, 72, 42, 10
	CONTROL		"SHA1", IDC_PROPS_SHA1, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 72, 45, 10
	CONTROL		"CRC32", IDC_PROPS_CRC32, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 147, 72, 52, 10
	CONTROL		"CRC64", IDC_PROPS_CRC64, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 17, 86, 52, 10
	CONTROL		"SHA256", IDC_PROPS_SHA256, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 82, 86, 62, 10
	CONTROL		"SHA512", IDC_PROPS_SHA512, "Button", BS_AUTOCHECKBOX | WS_TABSTOP, 147, 86, 62, 10
	PUSHBUTTON	"Calculate", IDC_PROPS_CALC, 17, 102, 60, 14
	PUSHBUTTON	"Copy", IDC_PROPS_COPY, 154, 102, 60, 14
	CONTROL		"", IDC_PROPS_PROGRESS, "msctls_progress32", WS_BORDER, 17, 122, 197, 10
	LTEXT		"Ready.", IDC_PROPS_STATUS, 17, 136, 197, 8
	EDITTEXT	IDC_PROPS_RESULT, 17, 148, 197, 34, ES_MULTILINE | ES_READONLY | ES_AUTOHSCROLL | ES_AUTOVSCROLL | WS_VSCROLL | WS_BORDER | WS_TABSTOP
END

